[global]
# Size and Positioning (Small, tucked in the top right)
width = 280
height = 80
offset = 15x40
origin = top-right
notification_limit = 3

# Aesthetics
font = JetBrainsMono Nerd Font 10
corner_radius = 6
frame_width = 1
frame_color = "#2C2C2C"
separator_color = frame

# Text formatting
markup = full
format = "<b>%s</b>\n%b"
word_wrap = yes
ignore_newline = no

# Spacing
padding = 12
horizontal_padding = 12
text_icon_padding = 12

# Behavior
sort = yes
idle_threshold = 120
sticky_history = yes
history_length = 20
mouse_left_click = close_current
mouse_right_click = close_all

[urgency_low]
background = "#121212"
foreground = "#717CB4"
timeout = 3

[urgency_normal]
background = "#121212"
foreground = "#EEFFFF"
frame_color = "#82AAFF"
timeout = 4

[urgency_critical]
background = "#1E1E1E"
foreground = "#FF5370"
frame_color = "#FF5370"
timeout = 0
